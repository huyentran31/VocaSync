# Copy to .env and fill. NEVER commit .env (see .gitignore). — Day 4 Security
# Google Gemini — the provider this build uses.
GEMINI_API_KEY=

# NOTE: the bundled ai_client (legacy) reads GEMINI_API_KEY / AI_API_KEY / OPENAI_API_KEY
# and supports AI_PROVIDER = gemini | openai_compatible. To run the AI features, set
# GEMINI_API_KEY (Gemini), OR AI_API_KEY + AI_PROVIDER=openai_compatible (+ AI_ENDPOINT, AI_MODEL).
AI_PROVIDER=gemini
# Model routing (Day-5). IMPORTANT: when AI_PROVIDER=gemini these MUST be Gemini ids,
# never a Claude id (a Claude id on the Gemini endpoint → HTTP 404).
#   AI_MODEL        = default workhorse for every call (more free-tier quota)
#   AI_MODEL_STRONG = used ONLY by extract_vocab's self-correct fix call (~20/day cap)
AI_MODEL=gemini-3.1-flash-lite
AI_MODEL_STRONG=gemini-3.1-flash-lite
# AI_API_KEY=
# AI_ENDPOINT=

# extract_vocab tuning (optional; bounded multi-call self-correct) — defaults shown
# EXTRACT_MIN_UNIQUE=8     # gather candidates until this many unique terms
# EXTRACT_MAX_CALLS=3      # hard cap on AI calls per extraction run (short single-pass mode)
# Long-script coverage (S9): split a long transcript into windows + gather from each.
# EXTRACT_CHUNK_LINES=500      # only chunk transcripts LONGER than this many lines (demo clips stay single-pass)
# EXTRACT_LINES_PER_CHUNK=250  # window size when chunking
# EXTRACT_MAX_CHUNKS=6         # cap windows (bounds the AI calls on a very long film)

# enrich review knobs (optional; defaults shown) — S14 T6/T7
# LOW_CONFIDENCE_THRESHOLD=0.7   # enrich confidence below this -> needs_review
# POLYSEMY_REVIEW_MIN=5          # a term with >= this many WordNet senses -> always needs_review

# Media / Anki clips (optional; safe defaults in config.py).
# FFMPEG_PATH: ffmpeg binary (default "ffmpeg" on PATH; imageio-ffmpeg works, no ffprobe needed).
# FFMPEG_PATH=ffmpeg
# ANKI_CLIP_PAD (S18 P0-1): seconds of padding added to EACH edge of an Anki audio/screenshot
# clip so a short line isn't clipped mid-word or into silence. Default 0.2. If onsets sound
# cut off during acceptance testing, raise to 0.3 (larger pad can bleed into the next line on
# dense/fast dialogue). No code change needed — just edit .env and re-Commit.
# ANKI_CLIP_PAD=0.2

# ConceptNet (optional; supplements WordNet for used_for / has_context / OOV part_of).
# All have safe defaults in config.py — NO key required (public REST API). Defaults shown:
# CONCEPTNET_ENDPOINT=https://api.conceptnet.io
# CONCEPTNET_MIN_WEIGHT=1.5   # precision filter (1.0 = single source; raise to tighten)
# CONCEPTNET_TIMEOUT=10
# CONCEPTNET_PER_TERM=1       # 1 = Mine queries ConceptNet for every term (richer graph); 0 = off
# CONCEPTNET_MAX_EDGES=30     # cap edges fetched per lookup (anti graph-explosion)
